# Variables d'environnement Phase 2 — Open WebUI
# INSTRUCTIONS :
# 1. Copier ce fichier : Copy-Item .env.example .env
# 2. Générer une clé secrète aléatoire :
#    $secret = [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
#    Write-Host $secret
# 3. Remplacer CHANGEME_GENERATE_RANDOM_KEY par la valeur générée
# 4. Ne pas committer le fichier .env (déjà dans .gitignore)

WEBUI_SECRET_KEY=CHANGEME_GENERATE_RANDOM_KEY
