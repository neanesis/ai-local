# Variables d'environnement Phase 3 — OpenHands
# INSTRUCTIONS :
# 1. Copier ce fichier : Copy-Item .env.example .env
# 2. Remplacer REMPLACER_PAR_ID_MODELE_LMSTUDIO par l'ID exact du modèle actif
#    Commande : Invoke-RestMethod http://localhost:1234/v1/models | ConvertTo-Json
# 3. Ne pas committer le fichier .env (déjà dans .gitignore)

# Clé API pour LM Studio (valeur arbitraire, LM Studio ne vérifie pas la clé)
OPENAI_API_KEY=lm-studio

# Modèle LLM à utiliser (ID exact retourné par LM Studio)
# Exemple : qwen2.5-coder-14b-instruct
LLM_MODEL=REMPLACER_PAR_ID_MODELE_LMSTUDIO
